[sub_resource type="Resource" id="Resource_v7505"]
script = ExtResource("9_pxf6e")
text = "Merci encore pour ton aide!"
name = "Guiraud"
texture = ExtResource("10_pxf6e")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_slgb5"]
script = ExtResource("9_pxf6e")
text = "Tu devrais aller au marché, voir si quelqu'un sait quelque chose de ce livre."
name = "Guiraud"
texture = ExtResource("10_pxf6e")
metadata/_custom_type_script = "uid://c3h3244feas37"

