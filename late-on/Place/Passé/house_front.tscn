[sub_resource type="Resource" id="Resource_2ey88"]
script = ExtResource("9_pxf6e")
text = "Ma commode à épices, ça sent fort !"
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_i7un0"]
script = ExtResource("9_pxf6e")
text = "Mon comptoir de vente."
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_uw7m8"]
script = ExtResource("9_pxf6e")
text = "Du millepertuis que je fais sécher à l'air libre."
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_8oxes"]
script = ExtResource("9_pxf6e")
text = "Mon affiche \"Épices\", je l'ai fait peindre par un de mes artistes favoris."
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_20hwg"]
script = ExtResource("9_pxf6e")
text = "Il était de passage il y a de cela un an, c'était une belle journée ensoleillée de printemps."
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_ytwuq"]
script = ExtResource("9_pxf6e")
text = "C'est étrange, quand je pense au printemps je pense aussi aux épices, aux fleurs."
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_bf2m5"]
script = ExtResource("9_pxf6e")
text = "Les arômes de la nature qui se mélangent et ces expressions si singulières."
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_1loiy"]
script = ExtResource("9_pxf6e")
text = "En fait les épices, c'est ma passion."
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_lp6mb"]
script = ExtResource("9_pxf6e")
text = "Bien le bonjour, monsieur."
name = "Guiraud"
texture = ExtResource("10_pxf6e")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_2rouy"]
script = ExtResource("9_pxf6e")
text = "Bonjour, Guiraud. Quel vent t'amène?"
texture = ExtResource("10_pxf6e")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_08hii"]
script = ExtResource("9_pxf6e")
text = "Je suis bien embêté. J'ai fait tomber mes notes."
name = "Guiraud"
texture = ExtResource("10_pxf6e")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_keq82"]
script = ExtResource("9_pxf6e")
text = "Les examens de la faculté de médecine approchent... J'ai peur de ne pas m'y retrouver."
name = "Guiraud"
texture = ExtResource("10_pxf6e")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_th84v"]
script = ExtResource("9_pxf6e")
text = "Très bien, bon courage. Je cherche un livre en particulier, sais-tu qui pourrait m'aiguiller?"
texture = ExtResource("10_pxf6e")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_2u0rt"]
script = ExtResource("9_pxf6e")
text = "Je pourrai te présenter quelqu'un, mais il faut que je réorganise ces notes..."
name = "Guiraud"
texture = ExtResource("10_pxf6e")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_w52bc"]
script = ExtResource("9_pxf6e")
text = "Des feuilles remplies sur le sol."
metadata/_custom_type_script = "uid://c3h3244feas37"

