[sub_resource type="Resource" id="Resource_auvlp"]
script = ExtResource("2_j8xeh")
text = "Hello! Je suis ton Chronopote personnalisé!"
name = "???"
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_7nxwm"]
script = ExtResource("2_j8xeh")
text = "Roh."
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_uknis"]
script = ExtResource("2_j8xeh")
text = "Je suis là pour t'aider dans tes tâches! J'espère que tu es bien motivé aujourd'hui!"
name = "Chronopote"
texture = ExtResource("3_sugd2")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_x0liy"]
script = ExtResource("2_j8xeh")
text = "Euh, oui oui, comme d'habitude."
texture = ExtResource("3_sugd2")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_8hxjr"]
script = ExtResource("2_j8xeh")
text = "(J'ai complètement oublié ce qui était prévu aujourd'hui)"
texture = ExtResource("3_sugd2")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_sh7tu"]
script = ExtResource("2_j8xeh")
text = "C'est parti! C'est l'heure de découvrir ton correspondant! Il vit au Moyen-Âge cette fois."
name = "Chronopote"
texture = ExtResource("3_sugd2")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_cml1u"]
script = ExtResource("2_j8xeh")
text = "Il s'agit d'un marchant au XIIIe siècle! Quelle chance de pouvoir l'aider à remplir sa mission!"
name = "Chronopote"
texture = ExtResource("3_sugd2")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_4iv2k"]
script = ExtResource("2_j8xeh")
text = "Aide le suffisamment pour que sa tâche soit accomplie et tu gagnera 200 crédits!"
name = "Chronopote"
texture = ExtResource("3_sugd2")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_yf3hy"]
script = ExtResource("2_j8xeh")
text = "Tu peux consulter les informations de cette mission en cliquant sur l'icône de maison."
name = "Chronopote"
texture = ExtResource("3_sugd2")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_qrk2t"]
script = ExtResource("2_j8xeh")
text = "Ou tu peux également me demander conseil à n'importe quel moment en me cliquant dessus!"
name = "Chronopote"
texture = ExtResource("3_sugd2")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_6kcf5"]
script = ExtResource("2_j8xeh")
text = "Bonne chance, et n'hésite pas à communiquer avec ton correspondant autant que possible!"
name = "Chronopote"
texture = ExtResource("3_sugd2")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="Resource" id="Resource_u2bti"]
script = ExtResource("2_j8xeh")
text = "N'hésite pas non plus à commander les dernières sorties de Global Corp! Notamment le tout nouveau Com'Bot© Xperia capable désormais de converser dans 300 langues, et sur plus de 2 000 000 de sujets! Pour uniquement 17 000 000 de crédits!"
name = "Chronopote"
texture = ExtResource("3_sugd2")
metadata/_custom_type_script = "uid://c3h3244feas37"

[sub_resource type="StyleBoxEmpty" id="StyleBoxEmpty_sugd2"]

[sub_resource type="Resource" id="Resource_8broe"]
script = ExtResource("2_j8xeh")
text = "Alors? Besoin de l'aide de ton Chronopote©?"
name = "Chronopote"
texture = ExtResource("3_sugd2")
metadata/_custom_type_script = "uid://c3h3244feas37"

