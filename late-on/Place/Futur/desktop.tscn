[sub_resource type="Resource" id="Resource_j1jln"]
script = ExtResource("2_j8xeh")
text = "Elle est spécialement conçue pour toi, tu devrais pouvoir la repérer avec un peu d'effort! Une fois cela fait, clique dessus!"
